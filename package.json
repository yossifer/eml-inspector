{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      "**/node_modules/**",
      "package.json",
      "package-lock.json",
      "README.md"
    ],
    "headers": [
      {
        "source": "**/*.webmanifest",
        "headers": [{ "key": "Content-Type", "value": "application/manifest+json" }]
      },
      {
        "source": "/sw.js",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      }
    ]
  }
}
