:root{
  --canvas:#EDF0F3; --surface:#FFFFFF; --ink:#16202B; --muted:#5B6B7A; --faint:#8696A5;
  --hair:#D8DEE5; --hair-soft:#E7ECF1; --accent:#0B7A6B; --accent-deep:#075E52;
  --warn:#B45309; --warn-soft:#FBEFE0;
  --mono: ui-monospace, "Roboto Mono", "SF Mono", Menlo, Consolas, monospace;
  --sans: system-ui, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  --radius:10px; --shadow:0 1px 2px rgba(22,32,43,.06), 0 8px 24px rgba(22,32,43,.06);
}
*{box-sizing:border-box;}
html,body{height:100%;}
body{margin:0;background:var(--canvas);color:var(--ink);font-family:var(--sans);font-size:15px;line-height:1.5;-webkit-font-smoothing:antialiased;}
.app{display:grid;grid-template-columns:300px 1fr;height:100vh;}

.side{background:var(--surface);border-right:1px solid var(--hair);display:flex;flex-direction:column;min-height:0;}
.brand{padding:18px 18px 14px;border-bottom:1px solid var(--hair-soft);}
.brand h1{font-family:var(--mono);font-size:14px;letter-spacing:.14em;text-transform:uppercase;margin:0;font-weight:600;}
.brand p{margin:4px 0 0;font-size:12px;color:var(--faint);letter-spacing:.02em;}
.drop{margin:14px;border:1.5px dashed var(--hair);border-radius:var(--radius);padding:20px 14px;text-align:center;cursor:pointer;transition:border-color .15s,background .15s;color:var(--muted);font-size:13px;}
.drop:hover{border-color:var(--accent);}
.drop.over{border-color:var(--accent);background:#F0FAF8;color:var(--accent-deep);}
.drop strong{display:block;color:var(--ink);font-size:14px;margin-bottom:3px;}
.drop .hint{font-family:var(--mono);font-size:11px;color:var(--faint);margin-top:8px;}
.filelist{list-style:none;margin:0;padding:6px 8px;overflow-y:auto;flex:1;min-height:0;}
.fileitem{padding:9px 10px;border-radius:8px;cursor:pointer;border:1px solid transparent;margin-bottom:2px;}
.fileitem:hover{background:var(--hair-soft);}
.fileitem.active{background:#EAF6F3;border-color:#BFE3DB;}
.fileitem .fn{font-size:13px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.fileitem .meta{font-family:var(--mono);font-size:11px;color:var(--faint);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:1px;}
.side-foot{padding:10px 16px;border-top:1px solid var(--hair-soft);font-size:11px;color:var(--faint);}

.main{overflow-y:auto;min-height:0;padding:24px 28px 60px;}
.empty{height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;color:var(--faint);text-align:center;gap:10px;}
.empty .glyph{font-family:var(--mono);font-size:40px;color:var(--hair);}

.envelope{background:var(--surface);border:1px solid var(--hair);border-left:3px solid var(--accent);border-radius:var(--radius);box-shadow:var(--shadow);overflow:hidden;}
.subject{padding:18px 22px 14px;border-bottom:1px solid var(--hair-soft);}
.subject .lbl{font-family:var(--mono);font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:var(--faint);}
.subject h2{margin:3px 0 0;font-size:20px;font-weight:600;line-height:1.3;}
.fields{padding:6px 22px 16px;}
.field{display:grid;grid-template-columns:84px 1fr;gap:14px;padding:5px 0;align-items:baseline;border-bottom:1px solid var(--hair-soft);}
.field:last-child{border-bottom:none;}
.field .k{font-family:var(--mono);font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--faint);padding-top:2px;}
.field .v{font-size:14px;word-break:break-word;}
.field .v.addr{font-family:var(--mono);font-size:13px;}

.bar{display:flex;gap:8px;flex-wrap:wrap;align-items:center;margin:18px 0 12px;}
.seg{display:inline-flex;border:1px solid var(--hair);border-radius:8px;overflow:hidden;background:var(--surface);}
.seg button{border:none;background:transparent;padding:7px 14px;font-family:var(--mono);font-size:12px;letter-spacing:.04em;cursor:pointer;color:var(--muted);border-right:1px solid var(--hair);}
.seg button:last-child{border-right:none;}
.seg button.on{background:var(--accent);color:#fff;}
.seg button:disabled{opacity:.4;cursor:not-allowed;}
.btn{border:1px solid var(--hair);background:var(--surface);color:var(--ink);padding:7px 13px;border-radius:8px;font-size:13px;cursor:pointer;font-family:var(--sans);}
.btn:hover{border-color:var(--accent);color:var(--accent-deep);}
.btn.accent{background:var(--accent);border-color:var(--accent);color:#fff;}
.btn.accent:hover{background:var(--accent-deep);}
.notice{display:flex;align-items:center;gap:10px;background:var(--warn-soft);border:1px solid #EFD8B8;color:#7A3D06;border-radius:8px;padding:8px 12px;font-size:13px;margin:0 0 12px;}
.notice .btn{margin-left:auto;padding:4px 10px;font-size:12px;}

.body-wrap{background:var(--surface);border:1px solid var(--hair);border-radius:var(--radius);box-shadow:var(--shadow);overflow:hidden;}
iframe.body{width:100%;height:58vh;border:none;display:block;background:#fff;}
pre.body-text{margin:0;padding:20px 22px;white-space:pre-wrap;word-break:break-word;font-family:var(--mono);font-size:13px;line-height:1.6;color:var(--ink);max-height:58vh;overflow:auto;}
pre.raw{margin:0;padding:20px 22px;white-space:pre-wrap;word-break:break-word;font-family:var(--mono);font-size:12px;line-height:1.55;color:var(--muted);max-height:58vh;overflow:auto;}

.att-head{font-family:var(--mono);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--faint);margin:22px 0 10px;}
.att-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:10px;}
.att{display:flex;align-items:center;gap:12px;background:var(--surface);border:1px solid var(--hair);border-radius:10px;padding:11px 12px;}
.att .ic{width:38px;height:38px;flex:none;border-radius:8px;background:#EAF6F3;color:var(--accent-deep);display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-size:10px;font-weight:600;}
.att .info{min-width:0;flex:1;}
.att .name{font-size:13px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.att .sub{font-family:var(--mono);font-size:11px;color:var(--faint);}
.att .dl{flex:none;}
.att .dl .btn{padding:6px 11px;font-size:12px;}

@media (max-width:760px){
  .app{grid-template-columns:1fr;grid-template-rows:auto 1fr;}
  .side{border-right:none;border-bottom:1px solid var(--hair);max-height:42vh;}
  iframe.body{height:48vh;}
}
@media (prefers-reduced-motion:reduce){*{transition:none!important;}}
:focus-visible{outline:2px solid var(--accent);outline-offset:2px;}
